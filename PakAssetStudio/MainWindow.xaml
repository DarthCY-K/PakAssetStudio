<ui:FluentWindow x:Class="PakAssetStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:l="clr-namespace:PakAssetStudio.Services"
        Title="PAK Asset Studio" Width="1280" Height="930"
        MinWidth="1120" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

  <ui:FluentWindow.Resources>
    <!-- 胶囊式选项卡 -->
    <Style x:Key="WorkspaceTabItem" TargetType="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="16,7" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="#14FFFFFF" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="True" />
                  <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="WorkspaceTabControl" TargetType="TabControl">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabControl">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0" Background="#12FFFFFF" CornerRadius="8" Padding="4" HorizontalAlignment="Left" Margin="0,0,0,10">
                <TabPanel IsItemsHost="True" />
              </Border>
              <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ContentPresenter ContentSource="SelectedContent" />
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 深色数据网格 -->
    <Style x:Key="GridCellText" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- 首列增加左边距，避免文字贴着行高亮边缘 -->
    <Style x:Key="GridCellTextFirst" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
      <Setter Property="Padding" Value="10,0,0,0" />
    </Style>
    <!-- 窄列内容水平居中，与表头对齐 -->
    <Style x:Key="GridCellTextCenter" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style x:Key="GridColumnHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#0DFFFFFF" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Height" Value="38" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style x:Key="GridColumnHeaderFirst" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridColumnHeader}">
      <Setter Property="Padding" Value="22,0,12,0" />
    </Style>
    <Style x:Key="GridColumnHeaderCenter" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridColumnHeader}">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="WorkspaceDataGrid" TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="#14FFFFFF" />
      <Setter Property="VerticalGridLinesBrush" Value="#0AFFFFFF" />
      <Setter Property="RowBackground" Value="Transparent" />
      <Setter Property="AlternatingRowBackground" Value="#08FFFFFF" />
      <Setter Property="RowHeight" Value="36" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridColumnHeader}" />
      <Setter Property="CellStyle">
        <Setter.Value>
          <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="RowStyle">
        <Setter.Value>
          <Style TargetType="DataGridRow">
            <Style.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#0DFFFFFF" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="PAK ASSET STUDIO">
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Cube24" FontSize="15" />
      </ui:TitleBar.Icon>
      <ui:TitleBar.TrailingContent>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock x:Name="VersionText" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0" />
          <ComboBox x:Name="LanguageBox" Width="116" Margin="0,0,10,0" VerticalAlignment="Center"
                    DisplayMemberPath="Name" SelectionChanged="LanguageBox_SelectionChanged" />
          <Border Background="#1AFFFFFF" CornerRadius="11" Padding="11,4" VerticalAlignment="Center" Margin="0,0,10,0">
            <StackPanel Orientation="Horizontal">
              <Ellipse x:Name="HeaderStatusDot" Width="8" Height="8" Fill="#35D0A5" VerticalAlignment="Center" Margin="0,0,7,0" />
              <TextBlock x:Name="HeaderStatusText" Text="{l:Loc App_Ready}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </StackPanel>
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <Grid Grid.Row="1" Margin="22,4,22,18">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="396" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

    <!-- 左侧：配置面板 -->
    <ScrollViewer Grid.Row="0" Grid.Column="0" Margin="0,0,14,0" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ui:Card Padding="18,14">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
              <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="{l:Loc Input_Title}" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <TextBlock Text="{l:Loc Input_GameDir}" Style="{StaticResource FieldLabel}" Margin="0,10,0,5" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox x:Name="GameDirectoryBox" PlaceholderText="{l:Loc Input_GameDirPlaceholder}" TextChanged="PathBox_TextChanged" />
              <ui:Button Grid.Column="1" Margin="8,0,0,0" ToolTip="{l:Loc Input_BrowseGameTip}" Click="BrowseGame_Click">
                <ui:Button.Icon>
                  <ui:SymbolIcon Symbol="FolderOpen20" />
                </ui:Button.Icon>
              </ui:Button>
            </Grid>

            <TextBlock Text="{l:Loc Input_OutputDir}" Style="{StaticResource FieldLabel}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox x:Name="OutputDirectoryBox" PlaceholderText="{l:Loc Input_OutputPlaceholder}" TextChanged="PathBox_TextChanged" />
              <ui:Button Grid.Column="1" Margin="8,0,0,0" ToolTip="{l:Loc Input_BrowseOutputTip}" Click="BrowseOutput_Click">
                <ui:Button.Icon>
                  <ui:SymbolIcon Symbol="FolderOpen20" />
                </ui:Button.Icon>
              </ui:Button>
            </Grid>
          </StackPanel>
        </ui:Card>

        <ui:Card Padding="18,14" Margin="0,12,0,0">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
              <ui:SymbolIcon Symbol="SlideSettings24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="{l:Loc Profile_Title}" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="118" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                  <TextBlock Text="{l:Loc Profile_Ue4Label}" Style="{StaticResource FieldLabel}" Margin="0" />
                  <Border x:Name="ProfileAutoHint" Visibility="Collapsed" Margin="6,0,0,0" Padding="6,1"
                          CornerRadius="7" Background="{DynamicResource AccentFillColorTertiaryBrush}">
                    <TextBlock Text="{l:Loc Profile_AutoBadge}" FontSize="10" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" />
                  </Border>
                </StackPanel>
                <ComboBox x:Name="GameProfileBox" IsEditable="True" SelectedIndex="26"
                          SelectionChanged="GameProfileBox_Changed">
                  <ComboBoxItem Content="ue4.0" /><ComboBoxItem Content="ue4.1" /><ComboBoxItem Content="ue4.2" />
                  <ComboBoxItem Content="ue4.3" /><ComboBoxItem Content="ue4.4" /><ComboBoxItem Content="ue4.5" />
                  <ComboBoxItem Content="ue4.6" /><ComboBoxItem Content="ue4.7" /><ComboBoxItem Content="ue4.8" />
                  <ComboBoxItem Content="ue4.9" /><ComboBoxItem Content="ue4.10" /><ComboBoxItem Content="ue4.11" />
                  <ComboBoxItem Content="ue4.12" /><ComboBoxItem Content="ue4.13" /><ComboBoxItem Content="ue4.14" />
                  <ComboBoxItem Content="ue4.15" /><ComboBoxItem Content="ue4.16" /><ComboBoxItem Content="ue4.17" />
                  <ComboBoxItem Content="ue4.18" /><ComboBoxItem Content="ue4.19" /><ComboBoxItem Content="ue4.20" />
                  <ComboBoxItem Content="ue4.21" /><ComboBoxItem Content="ue4.22" /><ComboBoxItem Content="ue4.23" />
                  <ComboBoxItem Content="ue4.24" /><ComboBoxItem Content="ue4.25" /><ComboBoxItem Content="ue4.26" />
                  <ComboBoxItem Content="ue4.27" />
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="{l:Loc Profile_Workers}" Style="{StaticResource FieldLabel}" Margin="0,0,0,5" />
                <ComboBox x:Name="WorkersBox" SelectedIndex="3">
                  <ComboBoxItem Content="2" /><ComboBoxItem Content="4" /><ComboBoxItem Content="6" />
                  <ComboBoxItem Content="8" /><ComboBoxItem Content="12" /><ComboBoxItem Content="16" />
                </ComboBox>
              </StackPanel>
            </Grid>

            <TextBlock Text="{l:Loc Profile_AesLabel}" Style="{StaticResource FieldLabel}" />
            <ui:PasswordBox x:Name="AesKeyBox" RevealButtonEnabled="True" ToolTip="{l:Loc Profile_AesTip}" />

            <ui:ToggleSwitch x:Name="LowResourceCheck" Content="{l:Loc Profile_LowResource}" Margin="0,14,0,2"
                             ToolTip="{l:Loc Profile_LowResourceTip}" />
          </StackPanel>
        </ui:Card>

        <ui:Card Padding="18,14" Margin="0,12,0,0">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Layer24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="{l:Loc Steps_Title}" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <ui:ToggleSwitch x:Name="ExtractCheck" Content="{l:Loc Steps_Extract}" IsChecked="True" Margin="0,12,0,0" />
            <ui:ToggleSwitch x:Name="ModelsCheck" Content="{l:Loc Steps_Models}" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="TexturesCheck" Content="{l:Loc Steps_Textures}" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="FbxCheck" Content="{l:Loc Steps_Fbx}" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="KeepGltfCheck" Content="{l:Loc Steps_KeepGltf}" Margin="0,8,0,0" />
            <ui:ToggleSwitch x:Name="MergeCheck" Content="{l:Loc Steps_Merge}" IsChecked="True" Margin="0,8,0,0"
                             ToolTip="{l:Loc Steps_MergeTip}" />
            <ui:ToggleSwitch x:Name="DeleteCookedCheck" Content="{l:Loc Steps_DeleteCooked}" IsChecked="True" Margin="0,8,0,0"
                             ToolTip="{l:Loc Steps_DeleteCookedTip}" />
            <ui:ToggleSwitch x:Name="OverwriteCheck" Content="{l:Loc Steps_Overwrite}" Margin="0,8,0,0" />
          </StackPanel>
        </ui:Card>

        <ui:InfoBar Margin="0,12,0,4" Severity="Informational" IsClosable="False" IsOpen="True"
                    Title="{l:Loc Safety_Title}"
                    Message="{l:Loc Safety_Message}" />
      </StackPanel>
    </ScrollViewer>

    <!-- 右侧：工作区 -->
    <Grid Grid.Row="0" Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Margin="0,2,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="{l:Loc Workspace_Title}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <TextBlock x:Name="WorkspaceSummaryText" Text="{l:Loc Workspace_SummaryEmpty}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:ToggleSwitch x:Name="ShowUnsupportedCheck" Content="{l:Loc Workspace_ShowUnsupported}" Margin="0,0,16,0"
                           ToolTip="{l:Loc Workspace_ShowUnsupportedTip}"
                           Checked="UnsupportedFilter_Changed" Unchecked="UnsupportedFilter_Changed" />
          <ui:Button x:Name="ScanButton" Content="{l:Loc Workspace_Scan}" Click="Scan_Click" MinWidth="118">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="ArrowSync20" />
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
      </Grid>

      <TabControl Grid.Row="1" Style="{StaticResource WorkspaceTabControl}">
        <TabItem Header="{l:Loc Tab_Paks}" Style="{StaticResource WorkspaceTabItem}">
          <Grid>
            <DataGrid x:Name="PakGrid" ItemsSource="{Binding PakEntries}" AutoGenerateColumns="False"
                      Style="{StaticResource WorkspaceDataGrid}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="{l:Loc Grid_Name}" Binding="{Binding Name}" Width="2*"
                                    ElementStyle="{StaticResource GridCellTextFirst}"
                                    HeaderStyle="{StaticResource GridColumnHeaderFirst}" />
                <DataGridTextColumn Header="{l:Loc Grid_Size}" Binding="{Binding SizeText}" Width="96"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="{l:Loc Grid_Version}" Binding="{Binding Version}" Width="76"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="{l:Loc Grid_Compression}" Binding="{Binding Compression}" Width="104"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="{l:Loc Grid_Files}" Binding="{Binding FileCount}" Width="76"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="{l:Loc Grid_Status}" Binding="{Binding Status}" Width="108"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
              </DataGrid.Columns>
            </DataGrid>
            <StackPanel x:Name="PakEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
              <ui:SymbolIcon Symbol="ArchiveMultiple24" FontSize="42" Foreground="#2EFFFFFF" HorizontalAlignment="Center" />
              <TextBlock x:Name="PakEmptyTitle" Text="{l:Loc Empty_Title}" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,6"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
              <TextBlock x:Name="PakEmptyHint" Text="{l:Loc Empty_Hint}" FontSize="12"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="{l:Loc Tab_Log}" Style="{StaticResource WorkspaceTabItem}">
          <RichTextBox x:Name="LogBox" IsReadOnly="True" IsDocumentEnabled="True"
                       VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto"
                       Background="#0E1512" Foreground="#A8BBB5" BorderThickness="0"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="14"
                       CaretBrush="#A8BBB5" SelectionBrush="{DynamicResource AccentFillColorTertiaryBrush}">
            <RichTextBox.Document>
              <FlowDocument PagePadding="0" />
            </RichTextBox.Document>
          </RichTextBox>
        </TabItem>
      </TabControl>
    </Grid>

    <!-- 底部：任务栏 -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" Padding="18,12"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
          <TextBlock x:Name="StageText" Text="{l:Loc Stage_Idle}" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <ProgressBar x:Name="TaskProgress" Height="6" Margin="0,9,0,0" Minimum="0" Maximum="100" Value="0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:Button x:Name="OpenOutputButton" ToolTip="{l:Loc Btn_OpenOutputTip}" Click="OpenOutput_Click">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="OpenFolder20" />
            </ui:Button.Icon>
          </ui:Button>
          <ui:Button x:Name="CancelButton" Content="{l:Loc Btn_Cancel}" Margin="8,0,0,0" Click="Cancel_Click" IsEnabled="False" MinWidth="88">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Dismiss20" />
            </ui:Button.Icon>
          </ui:Button>
          <ui:Button x:Name="StartButton" Content="{l:Loc Btn_Start}" Appearance="Primary" Margin="8,0,0,0" Click="Start_Click" MinWidth="128">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Play20" />
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
      </Grid>
    </Border>
    </Grid>
  </Grid>
</ui:FluentWindow>
