<Window x:Class="PakAssetStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PAK Asset Studio" Width="1240" Height="800"
        MinWidth="1060" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="70" />
      <RowDefinition Height="*" />
      <RowDefinition Height="68" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="#1D2926" BorderBrush="#2C3936" BorderThickness="0,0,0,1">
      <Grid Margin="24,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock Text="PAK ASSET STUDIO" Foreground="White" FontSize="20" FontWeight="SemiBold" />
          <TextBlock Text="UE4 PAK 解包、模型贴图导出与 FBX 转换" Foreground="#B9C6C2" FontSize="12" Margin="0,3,0,0" />
        </StackPanel>
        <Border Grid.Column="1" VerticalAlignment="Center" Background="#293A36" BorderBrush="#3B4D49" BorderThickness="1" CornerRadius="4" Padding="12,7">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="HeaderStatusDot" Width="8" Height="8" Fill="#63C7A8" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock x:Name="HeaderStatusText" Text="就绪" Foreground="#E8F0ED" FontSize="12" />
          </StackPanel>
        </Border>
      </Grid>
    </Border>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="380" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="22,8,22,24">
            <TextBlock Text="输入与输出" Style="{StaticResource SectionLabel}" />
            <TextBlock Text="游戏目录" FontSize="13" Margin="0,0,0,5" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="GameDirectoryBox" ToolTip="可拖入游戏目录或 Paks 目录" TextChanged="PathBox_TextChanged" />
              <Button Grid.Column="1" Content="📁" Width="40" Margin="7,0,0,0" Style="{StaticResource SecondaryButton}" Click="BrowseGame_Click" ToolTip="选择游戏目录" />
            </Grid>

            <TextBlock Text="输出目录" FontSize="13" Margin="0,13,0,5" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox x:Name="OutputDirectoryBox" TextChanged="PathBox_TextChanged" />
              <Button Grid.Column="1" Content="📁" Width="40" Margin="7,0,0,0" Style="{StaticResource SecondaryButton}" Click="BrowseOutput_Click" ToolTip="选择输出目录" />
            </Grid>

            <TextBlock Text="解析配置" Style="{StaticResource SectionLabel}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="112" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,10,0">
                <TextBlock Text="UE4 版本标签" FontSize="13" Margin="0,0,0,5" />
                <ComboBox x:Name="GameProfileBox" IsEditable="True" SelectedIndex="26">
                  <ComboBoxItem Content="ue4.0" /><ComboBoxItem Content="ue4.1" /><ComboBoxItem Content="ue4.2" />
                  <ComboBoxItem Content="ue4.3" /><ComboBoxItem Content="ue4.4" /><ComboBoxItem Content="ue4.5" />
                  <ComboBoxItem Content="ue4.6" /><ComboBoxItem Content="ue4.7" /><ComboBoxItem Content="ue4.8" />
                  <ComboBoxItem Content="ue4.9" /><ComboBoxItem Content="ue4.10" /><ComboBoxItem Content="ue4.11" />
                  <ComboBoxItem Content="ue4.12" /><ComboBoxItem Content="ue4.13" /><ComboBoxItem Content="ue4.14" />
                  <ComboBoxItem Content="ue4.15" /><ComboBoxItem Content="ue4.16" /><ComboBoxItem Content="ue4.17" />
                  <ComboBoxItem Content="ue4.18" /><ComboBoxItem Content="ue4.19" /><ComboBoxItem Content="ue4.20" />
                  <ComboBoxItem Content="ue4.21" /><ComboBoxItem Content="ue4.22" /><ComboBoxItem Content="ue4.23" />
                  <ComboBoxItem Content="ue4.24" /><ComboBoxItem Content="ue4.25" /><ComboBoxItem Content="ue4.26" />
                  <ComboBoxItem Content="ue4.27" />
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="并行任务" FontSize="13" Margin="0,0,0,5" />
                <ComboBox x:Name="WorkersBox" SelectedIndex="3">
                  <ComboBoxItem Content="2" /><ComboBoxItem Content="4" /><ComboBoxItem Content="6" />
                  <ComboBoxItem Content="8" /><ComboBoxItem Content="12" /><ComboBoxItem Content="16" />
                </ComboBox>
              </StackPanel>
            </Grid>

            <TextBlock Text="AES 密钥（可选）" FontSize="13" Margin="0,13,0,5" />
            <PasswordBox x:Name="AesKeyBox" MinHeight="34" Padding="9,6" BorderBrush="{StaticResource LineBrush}" ToolTip="仅用于已获授权的加密 PAK" />

            <TextBlock Text="处理步骤" Style="{StaticResource SectionLabel}" />
            <CheckBox x:Name="ExtractCheck" Content="解包所有可读取的 PAK" IsChecked="True" />
            <CheckBox x:Name="ModelsCheck" Content="导出静态模型与骨骼模型" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="TexturesCheck" Content="导出 PNG / HDR 贴图" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="FbxCheck" Content="将 glTF 转换为 FBX" IsChecked="True" Checked="Option_Changed" Unchecked="Option_Changed" />
            <CheckBox x:Name="KeepGltfCheck" Content="保留原 glTF，FBX 写入单独副本" IsChecked="True" />
            <CheckBox x:Name="OverwriteCheck" Content="覆盖已有输出文件" />

            <Border Background="#EEF5F2" BorderBrush="#CFE0DA" BorderThickness="1" CornerRadius="4" Padding="11" Margin="0,13,0,0">
              <TextBlock Text="程序不会修改原游戏目录。加密密钥仅传给本地工具，不写入报告。" TextWrapping="Wrap" Foreground="#36564E" FontSize="12" LineHeight="18" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="1" Margin="22,16,22,16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel>
            <TextBlock Text="工作区" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="WorkspaceSummaryText" Text="选择游戏目录后扫描 PAK" Foreground="{StaticResource MutedBrush}" FontSize="12" Margin="0,4,0,0" />
          </StackPanel>
          <Button Grid.Column="1" x:Name="ScanButton" Content="↻  扫描 PAK" Style="{StaticResource SecondaryButton}" Click="Scan_Click" MinWidth="112" />
        </Grid>

        <TabControl Grid.Row="1" Margin="0,14,0,0" Background="White" BorderBrush="{StaticResource LineBrush}">
          <TabItem Header="PAK 包">
            <Grid Background="White">
              <DataGrid x:Name="PakGrid" ItemsSource="{Binding PakEntries}" AutoGenerateColumns="False"
                        IsReadOnly="True" CanUserAddRows="False" HeadersVisibility="Column"
                        GridLinesVisibility="Horizontal" BorderThickness="0" RowHeight="34"
                        AlternatingRowBackground="#F8FAF9" SelectionMode="Single">
                <DataGrid.Columns>
                  <DataGridTextColumn Header="文件" Binding="{Binding Name}" Width="2*" />
                  <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="90" />
                  <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="72" />
                  <DataGridTextColumn Header="压缩" Binding="{Binding Compression}" Width="76" />
                  <DataGridTextColumn Header="文件数" Binding="{Binding FileCount}" Width="72" />
                  <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="82" />
                </DataGrid.Columns>
              </DataGrid>
            </Grid>
          </TabItem>
          <TabItem Header="运行日志">
            <Grid Background="#111816">
              <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                       VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                       Background="#111816" Foreground="#D4E1DD" BorderThickness="0"
                       FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="14" />
            </Grid>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>

    <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource LineBrush}" BorderThickness="0,1,0,0">
      <Grid Margin="22,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center">
          <TextBlock x:Name="StageText" Text="等待任务" FontWeight="SemiBold" FontSize="13" />
          <ProgressBar x:Name="TaskProgress" Height="6" Margin="0,8,28,0" Minimum="0" Maximum="100" Value="0" Foreground="{StaticResource AccentBrush}" Background="#E3E8E6" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button x:Name="OpenOutputButton" Content="📂" Width="40" Style="{StaticResource SecondaryButton}" Click="OpenOutput_Click" ToolTip="打开输出目录" />
          <Button x:Name="CancelButton" Content="取消" Style="{StaticResource SecondaryButton}" Margin="8,0,0,0" Click="Cancel_Click" IsEnabled="False" MinWidth="74" />
          <Button x:Name="StartButton" Content="▶  开始处理" Style="{StaticResource PrimaryButton}" Margin="8,0,0,0" Click="Start_Click" MinWidth="126" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
