<ui:FluentWindow x:Class="PakAssetStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="PAK Asset Studio" Width="1280" Height="930"
        MinWidth="1120" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">

  <ui:FluentWindow.Resources>
    <!-- 胶囊式选项卡 -->
    <Style x:Key="WorkspaceTabItem" TargetType="TabItem">
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Padding" Value="16,7" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border x:Name="TabBorder" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
              <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextOnAccentFillColorPrimaryBrush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabBorder" Property="Background" Value="#14FFFFFF" />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsSelected" Value="True" />
                  <Condition Property="IsMouseOver" Value="True" />
                </MultiTrigger.Conditions>
                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource AccentFillColorDefaultBrush}" />
              </MultiTrigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="WorkspaceTabControl" TargetType="TabControl">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabControl">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>
              <Border Grid.Row="0" Background="#12FFFFFF" CornerRadius="8" Padding="4" HorizontalAlignment="Left" Margin="0,0,0,10">
                <TabPanel IsItemsHost="True" />
              </Border>
              <Border Grid.Row="1" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                      BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
                <ContentPresenter ContentSource="SelectedContent" />
              </Border>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- 深色数据网格 -->
    <Style x:Key="GridCellText" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <!-- 首列增加左边距，避免文字贴着行高亮边缘 -->
    <Style x:Key="GridCellTextFirst" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
      <Setter Property="Padding" Value="10,0,0,0" />
    </Style>
    <!-- 窄列内容水平居中，与表头对齐 -->
    <Style x:Key="GridCellTextCenter" TargetType="TextBlock" BasedOn="{StaticResource GridCellText}">
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
    <Style x:Key="GridColumnHeader" TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="#0DFFFFFF" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="Height" Value="38" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="0,0,0,1" />
    </Style>
    <Style x:Key="GridColumnHeaderFirst" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridColumnHeader}">
      <Setter Property="Padding" Value="22,0,12,0" />
    </Style>
    <Style x:Key="GridColumnHeaderCenter" TargetType="DataGridColumnHeader" BasedOn="{StaticResource GridColumnHeader}">
      <Setter Property="HorizontalContentAlignment" Value="Center" />
    </Style>
    <Style x:Key="WorkspaceDataGrid" TargetType="DataGrid">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="#14FFFFFF" />
      <Setter Property="VerticalGridLinesBrush" Value="#0AFFFFFF" />
      <Setter Property="RowBackground" Value="Transparent" />
      <Setter Property="AlternatingRowBackground" Value="#08FFFFFF" />
      <Setter Property="RowHeight" Value="36" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="SelectionMode" Value="Single" />
      <Setter Property="ColumnHeaderStyle" Value="{StaticResource GridColumnHeader}" />
      <Setter Property="CellStyle">
        <Setter.Value>
          <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{DynamicResource AccentFillColorTertiaryBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="RowStyle">
        <Setter.Value>
          <Style TargetType="DataGridRow">
            <Style.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#0DFFFFFF" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>
  </ui:FluentWindow.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <ui:TitleBar Grid.Row="0" Title="PAK ASSET STUDIO">
      <ui:TitleBar.Icon>
        <ui:SymbolIcon Symbol="Cube24" FontSize="15" />
      </ui:TitleBar.Icon>
      <ui:TitleBar.TrailingContent>
        <Border Background="#1AFFFFFF" CornerRadius="11" Padding="11,4" VerticalAlignment="Center" Margin="0,0,10,0">
          <StackPanel Orientation="Horizontal">
            <Ellipse x:Name="HeaderStatusDot" Width="8" Height="8" Fill="#35D0A5" VerticalAlignment="Center" Margin="0,0,7,0" />
            <TextBlock x:Name="HeaderStatusText" Text="就绪" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </ui:TitleBar.TrailingContent>
    </ui:TitleBar>

    <Grid Grid.Row="1" Margin="22,4,22,18">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="396" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

    <!-- 左侧：配置面板 -->
    <ScrollViewer Grid.Row="0" Grid.Column="0" Margin="0,0,14,0" VerticalScrollBarVisibility="Auto">
      <StackPanel>
        <ui:Card Padding="18,14">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
              <ui:SymbolIcon Symbol="FolderOpen24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="输入与输出" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <TextBlock Text="游戏目录" Style="{StaticResource FieldLabel}" Margin="0,10,0,5" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox x:Name="GameDirectoryBox" PlaceholderText="选择或拖入游戏目录 / Paks 目录" TextChanged="PathBox_TextChanged" />
              <ui:Button Grid.Column="1" Margin="8,0,0,0" ToolTip="选择游戏目录" Click="BrowseGame_Click">
                <ui:Button.Icon>
                  <ui:SymbolIcon Symbol="FolderOpen20" />
                </ui:Button.Icon>
              </ui:Button>
            </Grid>

            <TextBlock Text="输出目录" Style="{StaticResource FieldLabel}" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <ui:TextBox x:Name="OutputDirectoryBox" PlaceholderText="资产导出位置" TextChanged="PathBox_TextChanged" />
              <ui:Button Grid.Column="1" Margin="8,0,0,0" ToolTip="选择输出目录" Click="BrowseOutput_Click">
                <ui:Button.Icon>
                  <ui:SymbolIcon Symbol="FolderOpen20" />
                </ui:Button.Icon>
              </ui:Button>
            </Grid>
          </StackPanel>
        </ui:Card>

        <ui:Card Padding="18,14" Margin="0,12,0,0">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
              <ui:SymbolIcon Symbol="SlideSettings24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="解析配置" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <Grid Margin="0,10,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="118" />
              </Grid.ColumnDefinitions>
              <StackPanel Margin="0,0,10,0">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                  <TextBlock Text="UE4 版本标签" Style="{StaticResource FieldLabel}" Margin="0" />
                  <Border x:Name="ProfileAutoHint" Visibility="Collapsed" Margin="6,0,0,0" Padding="6,1"
                          CornerRadius="7" Background="{DynamicResource AccentFillColorTertiaryBrush}">
                    <TextBlock Text="自动" FontSize="10" Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}" FontWeight="SemiBold" />
                  </Border>
                </StackPanel>
                <ComboBox x:Name="GameProfileBox" IsEditable="True" SelectedIndex="26"
                          SelectionChanged="GameProfileBox_Changed">
                  <ComboBoxItem Content="ue4.0" /><ComboBoxItem Content="ue4.1" /><ComboBoxItem Content="ue4.2" />
                  <ComboBoxItem Content="ue4.3" /><ComboBoxItem Content="ue4.4" /><ComboBoxItem Content="ue4.5" />
                  <ComboBoxItem Content="ue4.6" /><ComboBoxItem Content="ue4.7" /><ComboBoxItem Content="ue4.8" />
                  <ComboBoxItem Content="ue4.9" /><ComboBoxItem Content="ue4.10" /><ComboBoxItem Content="ue4.11" />
                  <ComboBoxItem Content="ue4.12" /><ComboBoxItem Content="ue4.13" /><ComboBoxItem Content="ue4.14" />
                  <ComboBoxItem Content="ue4.15" /><ComboBoxItem Content="ue4.16" /><ComboBoxItem Content="ue4.17" />
                  <ComboBoxItem Content="ue4.18" /><ComboBoxItem Content="ue4.19" /><ComboBoxItem Content="ue4.20" />
                  <ComboBoxItem Content="ue4.21" /><ComboBoxItem Content="ue4.22" /><ComboBoxItem Content="ue4.23" />
                  <ComboBoxItem Content="ue4.24" /><ComboBoxItem Content="ue4.25" /><ComboBoxItem Content="ue4.26" />
                  <ComboBoxItem Content="ue4.27" />
                </ComboBox>
              </StackPanel>
              <StackPanel Grid.Column="1">
                <TextBlock Text="并行任务" Style="{StaticResource FieldLabel}" Margin="0,0,0,5" />
                <ComboBox x:Name="WorkersBox" SelectedIndex="3">
                  <ComboBoxItem Content="2" /><ComboBoxItem Content="4" /><ComboBoxItem Content="6" />
                  <ComboBoxItem Content="8" /><ComboBoxItem Content="12" /><ComboBoxItem Content="16" />
                </ComboBox>
              </StackPanel>
            </Grid>

            <TextBlock Text="AES 密钥（可选）" Style="{StaticResource FieldLabel}" />
            <ui:PasswordBox x:Name="AesKeyBox" RevealButtonEnabled="True" ToolTip="仅用于已获授权的加密 PAK" />

            <ui:ToggleSwitch x:Name="LowResourceCheck" Content="低占用模式（速度更慢，减少卡顿）" Margin="0,14,0,2"
                             ToolTip="限制并行度，子进程以低优先级运行" />
          </StackPanel>
        </ui:Card>

        <ui:Card Padding="18,14" Margin="0,12,0,0">
          <StackPanel>
            <StackPanel Orientation="Horizontal">
              <ui:SymbolIcon Symbol="Layer24" FontSize="16" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0" />
              <TextBlock Text="处理步骤" Style="{StaticResource CardTitle}" />
            </StackPanel>

            <ui:ToggleSwitch x:Name="ExtractCheck" Content="解包所有可读取的 PAK" IsChecked="True" Margin="0,12,0,0" />
            <ui:ToggleSwitch x:Name="ModelsCheck" Content="导出静态模型与骨骼模型" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="TexturesCheck" Content="导出 PNG / HDR 贴图" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="FbxCheck" Content="将 glTF 转换为 FBX" IsChecked="True" Margin="0,8,0,0" Checked="Option_Changed" Unchecked="Option_Changed" />
            <ui:ToggleSwitch x:Name="KeepGltfCheck" Content="保留原 glTF，FBX 写入单独副本" IsChecked="True" Margin="0,8,0,0" />
            <ui:ToggleSwitch x:Name="OverwriteCheck" Content="覆盖已有输出文件" Margin="0,8,0,0" />
          </StackPanel>
        </ui:Card>

        <ui:InfoBar Margin="0,12,0,4" Severity="Informational" IsClosable="False" IsOpen="True"
                    Title="安全提示"
                    Message="程序不会修改原游戏目录。加密密钥仅传给本地工具，不写入报告。" />
      </StackPanel>
    </ScrollViewer>

    <!-- 右侧：工作区 -->
    <Grid Grid.Row="0" Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Margin="0,2,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="工作区" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <TextBlock x:Name="WorkspaceSummaryText" Text="选择游戏目录后扫描 PAK" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,4,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:ToggleSwitch x:Name="ShowUnsupportedCheck" Content="显示不支持的包" Margin="0,0,16,0"
                           ToolTip="默认隐藏无法读取的 PAK（如 Chromium 数据包）"
                           Checked="UnsupportedFilter_Changed" Unchecked="UnsupportedFilter_Changed" />
          <ui:Button x:Name="ScanButton" Content="扫描 PAK" Click="Scan_Click" MinWidth="118">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="ArrowSync20" />
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
      </Grid>

      <TabControl Grid.Row="1" Style="{StaticResource WorkspaceTabControl}">
        <TabItem Header="PAK 包" Style="{StaticResource WorkspaceTabItem}">
          <Grid>
            <DataGrid x:Name="PakGrid" ItemsSource="{Binding PakEntries}" AutoGenerateColumns="False"
                      Style="{StaticResource WorkspaceDataGrid}">
              <DataGrid.Columns>
                <DataGridTextColumn Header="文件" Binding="{Binding Name}" Width="2*"
                                    ElementStyle="{StaticResource GridCellTextFirst}"
                                    HeaderStyle="{StaticResource GridColumnHeaderFirst}" />
                <DataGridTextColumn Header="大小" Binding="{Binding SizeText}" Width="96"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="版本" Binding="{Binding Version}" Width="76"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="压缩" Binding="{Binding Compression}" Width="80"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="文件数" Binding="{Binding FileCount}" Width="76"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="86"
                                    ElementStyle="{StaticResource GridCellTextCenter}"
                                    HeaderStyle="{StaticResource GridColumnHeaderCenter}" />
              </DataGrid.Columns>
            </DataGrid>
            <StackPanel x:Name="PakEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
              <ui:SymbolIcon Symbol="ArchiveMultiple24" FontSize="42" Foreground="#2EFFFFFF" HorizontalAlignment="Center" />
              <TextBlock x:Name="PakEmptyTitle" Text="暂无 PAK 包" FontSize="15" FontWeight="SemiBold" Margin="0,16,0,6"
                         Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
              <TextBlock x:Name="PakEmptyHint" Text="选择游戏目录后点击“扫描 PAK”，或将目录直接拖入窗口" FontSize="12"
                         Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
            </StackPanel>
          </Grid>
        </TabItem>
        <TabItem Header="运行日志" Style="{StaticResource WorkspaceTabItem}">
          <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap"
                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                   Background="#0E1512" Foreground="#C9D8D2" BorderThickness="0"
                   FontFamily="Cascadia Mono, Consolas" FontSize="12" Padding="14"
                   CaretBrush="#C9D8D2" SelectionBrush="{DynamicResource AccentFillColorTertiaryBrush}" />
        </TabItem>
      </TabControl>
    </Grid>

    <!-- 底部：任务栏 -->
    <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,14,0,0" Padding="18,12"
            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel VerticalAlignment="Center" Margin="0,0,20,0">
          <TextBlock x:Name="StageText" Text="等待任务" FontWeight="SemiBold" FontSize="13" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
          <ProgressBar x:Name="TaskProgress" Height="6" Margin="0,9,0,0" Minimum="0" Maximum="100" Value="0" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <ui:Button x:Name="OpenOutputButton" ToolTip="打开输出目录" Click="OpenOutput_Click">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="OpenFolder20" />
            </ui:Button.Icon>
          </ui:Button>
          <ui:Button x:Name="CancelButton" Content="取消" Margin="8,0,0,0" Click="Cancel_Click" IsEnabled="False" MinWidth="88">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Dismiss20" />
            </ui:Button.Icon>
          </ui:Button>
          <ui:Button x:Name="StartButton" Content="开始处理" Appearance="Primary" Margin="8,0,0,0" Click="Start_Click" MinWidth="128">
            <ui:Button.Icon>
              <ui:SymbolIcon Symbol="Play20" />
            </ui:Button.Icon>
          </ui:Button>
        </StackPanel>
      </Grid>
    </Border>
    </Grid>
  </Grid>
</ui:FluentWindow>
